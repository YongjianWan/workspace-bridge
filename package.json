{
  "name": "workspace-bridge",
  "version": "1.2.0",
  "description": "CLI-first workspace analysis engine for local AI coding agents",
  "main": "cli.js",
  "scripts": {
    "start": "node cli.js --help",
    "audit": "node cli.js audit-summary --cwd . --json --quiet",
    "audit:file": "node cli.js audit-file --cwd . --file src/tools/dep-tools.js --json --quiet",
    "test": "node test/runner.js",
    "test:security": "node test/security-test.js",
    "test:functionality": "node test/functionality-test.js",
    "test:cache": "node test/cache-test.js",
    "test:function-impact": "node test/function-impact-test.js",
    "test:cli-fallback": "node test/cli-fallback-test.js",
    "test:analysis": "node test/analysis-test.js",
    "test:audit-diff": "node test/audit-diff-test.js",
    "test:overview": "node test/overview-tools-test.js",
    "test:integration-core": "node test/integration-core-test.js",
    "test:roles": "node test/role-detection-test.js",
    "test:coverage": "c8 --all --include='src/**' --reporter=text --reporter=html node test/runner.js",
    "benchmark:perf": "node scripts/benchmark-perf.js",
    "benchmark": "node scripts/benchmark-perf.js --files 620 --changes 12 --max-ms 15000 --max-function-ms 60000",
    "benchmark:compare": "node benchmark/compare.js --base main",
    "benchmark:ci": "npm run benchmark && npm run benchmark:compare",
    "workflow:run": "node scripts/workflow-loop.js --task .workflow-task.json",
    "workflow:dry-run": "node scripts/workflow-loop.js --task .workflow-task.json --dry-run",
    "cli:fallback": "node scripts/cli-fallback.js",
    "self-audit": "node scripts/self-audit.js",
    "debug": "DEBUG=1 node cli.js audit-summary --cwd . --json"
  },
  "keywords": [
    "cli",
    "ai",
    "coding",
    "workspace",
    "indexing",
    "diagnostics"
  ],
  "author": "sdses",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "workspace-bridge": "cli.js",
    "workspace-bridge-cli": "cli.js"
  },
  "files": [
    "cli.js",
    "src/**",
    "skills/**",
    "scripts/cli-fallback.js",
    "scripts/python_ast_parser.py",
    "scripts/java_ast_parser.py",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "better-sqlite3": "^12.10.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.25.3"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
