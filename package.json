{
  "name": "workspace-bridge",
  "version": "0.7.0",
  "description": "CLI-first workspace analysis engine for local AI coding agents",
  "main": "cli.js",
  "scripts": {
    "start": "node cli.js --help",
    "audit": "node cli.js audit-summary --cwd . --json --quiet",
    "audit:file": "node cli.js audit-file --cwd . --file src\\tools\\dep-tools.js --json --quiet",
    "test": "node test/security-test.js",
    "test:security": "node test/security-test.js",
    "test:functionality": "node test/functionality-test.js",
    "test:analysis": "node test/analysis-test.js",
    "test:audit-diff": "node test/audit-diff-test.js",
    "test:roles": "node test/role-detection-test.js",
    "test:all": "node test/functionality-test.js && node test/analysis-test.js && node test/role-detection-test.js && node test/audit-diff-test.js",
    "debug": "DEBUG=1 node cli.js audit-summary --cwd . --json"
  },
  "keywords": [
    "cli",
    "ai",
    "coding",
    "workspace",
    "indexing",
    "diagnostics"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "workspace-bridge": "./cli.js",
    "workspace-bridge-cli": "./cli.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
