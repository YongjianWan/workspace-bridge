{
  "name": "workspace-bridge",
  "version": "0.7.0",
  "description": "Workspace analysis engine with MCP and local CLI entrypoints",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:cli": "node cli.js",
    "audit": "node cli.js audit-summary --cwd . --json --quiet",
    "audit:file": "node cli.js audit-file --cwd . --file src\\tools\\dep-tools.js --json --quiet",
    "start:http": "MCP_MODE=http node server.js",
    "test": "node test/security-test.js",
    "test:security": "node test/security-test.js",
    "test:mcp": "node test/mcp-test.js",
    "test:functionality": "node test/functionality-test.js",
    "test:analysis": "node test/analysis-test.js",
    "test:all": "node test/mcp-test.js && node test/functionality-test.js && node test/analysis-test.js",
    "debug": "DEBUG=1 node server.js"
  },
  "keywords": [
    "mcp",
    "ai",
    "coding",
    "workspace",
    "indexing",
    "diagnostics"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "workspace-bridge": "./server.js",
    "workspace-bridge-cli": "./cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.8.0",
    "express": "^4.18.2"
  }
}
